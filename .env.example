# UpstreamWX configuration (copy to .env; .env is git-ignored).
# M0.0 needs NO secrets — NOMADS, AWS Open Data, and USGS services are anonymous.
# These are documented now so the loading pattern (src/upstreamwx/config.py) is ready.

# Root directory for runtime caches (raw GRIB2 pulls, WBD downloads). Git-ignored.
UPSTREAMWX_DATA_DIR=./data

# Override the SREF source base URL discovered by Spike A (optional).
# UPSTREAMWX_SREF_BASE_URL=

# Future (M0.2): Anthropic API key for SITREP natural-language framing (Claude Haiku).
# ANTHROPIC_API_KEY=
