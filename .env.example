# UpstreamWX configuration (copy to .env; .env is git-ignored).
# M0.0 needs NO secrets — NOMADS, AWS Open Data, and USGS services are anonymous.
# These are documented now so the loading pattern (src/upstreamwx/config.py) is ready.

# Root directory for runtime caches (raw GRIB2 pulls, WBD downloads). Git-ignored.
UPSTREAMWX_DATA_DIR=./data

# Override the SREF source base URL discovered by Spike A (optional).
# UPSTREAMWX_SREF_BASE_URL=

# Override the HREF source base URL (same-day supplement, Spike C; optional).
# UPSTREAMWX_HREF_BASE_URL=

# NWS API (api.weather.gov) requires a self-identifying User-Agent with a contact
# (FR-5). Set this to your own app/contact for production use (M0.1 ingest).
# UPSTREAMWX_NWS_USER_AGENT=UpstreamWX/0.1 (+https://upstreamwx.com; you@example.com)

# Anthropic API key for SITREP natural-language framing (Claude Haiku, M0.2 FR-21).
# Set this to enable `upstreamwx` framing; without it the CLI emits the structured
# render only. Read directly as ANTHROPIC_API_KEY (no UPSTREAMWX_ prefix).
# ANTHROPIC_API_KEY=
