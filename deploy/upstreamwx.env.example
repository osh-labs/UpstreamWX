# UpstreamWX runtime environment (production).
#
# Installed to /etc/upstreamwx/upstreamwx.env and loaded by the systemd unit as its
# EnvironmentFile. This is the deployment analogue of the dev-time .env (config.py reads
# the same UPSTREAMWX_* vars). Keep mode 0640, owner root:upstreamwx — it holds secrets.
#
# bootstrap.sh installs this file from the example ONLY if it does not already exist, so
# editing the live file is safe across redeploys.

# Runtime cache root (raw GRIB2 pulls, WBD downloads). Owned by the service user; lives
# off the code tree so a redeploy never clears it (FR-12 / NOMADS ~2-day retention).
# NOTE: leave this UNSET here — the systemd unit pins UPSTREAMWX_DATA_DIR to the deploy's
# DEPLOY_DATA_DIR so it always matches ReadWritePaths (and differs between staging/prod). Set
# it only for a non-systemd/manual run. A hardcoded path here would send staging at the prod
# dir (a read-only, unowned path → PermissionError).
# UPSTREAMWX_DATA_DIR=/var/lib/upstreamwx

# Keep the recurring GEFS/REFS refresh scheduler ON — this is the always-on host whose
# whole job is to hold a current briefing cache (FR-12, roadmap §M0.1.1). Set to 0 only
# for a worker-less deployment (REFS will degrade without it).
UPSTREAMWX_API_ENABLE_SCHEDULER=1

# Dead-man's-switch monitoring (FR-12). A Healthchecks.io (or compatible) ping URL the
# refresh scheduler hits each cycle (".../start" before, base on success, ".../fail" on
# error). A stalled scheduler — stale briefings with no error — then alerts you instead of
# going unnoticed. Create a check at https://healthchecks.io with period ~6 h plus a grace
# window, and paste its ping URL here. Secret-ish; never commit it.
# Leave unset to disable. PRODUCTION: strongly recommended.
# UPSTREAMWX_HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# REFS feed selection (HREF replacement, NWS SCN 26-47/26-48).
#   aws          — AWS noaa-rrfs-pds prototype bucket (default; validated end-to-end)
#   nomads_para  — NOMADS parallel feed (live ~2026-06-09; use if AWS is unreachable)
#   nomads_prod  — NOMADS production feed (authoritative post-2026-08-31 EOL cutover)
# Switch to nomads_prod after 2026-08-31 when the production REFS feed goes live.
# UPSTREAMWX_REFS_SOURCE=aws

# Recent REFS runs (00/06/12/18Z) to keep in the on-disk cache before pruning.
# Default 3 keeps the prior run for spin-up backfill. Cache lives under
# UPSTREAMWX_DATA_DIR/refs and survives restarts.
# UPSTREAMWX_REFS_CACHE_KEEP_CYCLES=3

# ── Performance / resource limits (small-host safety) ─────────────────────────────────
# All of these have safe defaults in config.py; uncomment only to override on THIS host.
# NOTE: deploy.sh never rewrites this file — to change a value on a running server, edit it
# here and `sudo systemctl restart upstreamwx-api`. The values shown ARE the current defaults.

# GEFS decode process pool. OFF by default: each spawn worker re-imports the scientific stack
# (xarray + cfgrib + regionmask/rasterio + timezonefinder, ~300-500 MB RSS each) and OOM-killed
# uvicorn on a ≤2 GB host. Leave it off unless the host has real RAM headroom (~4 GB+); then set
# a small worker count. With it off, GEFS still decodes in-process (cropped, memory-light).
# UPSTREAMWX_API_ENABLE_DECODE_POOL=0
# UPSTREAMWX_DECODE_POOL_WORKERS=2

# In-process decoded-grid LRU byte budget (memory-aware eviction). GEFS grids are cropped at
# decode time (~KB), so this mainly bounds the larger REFS native grids. Default ~128 MiB.
# UPSTREAMWX_DECODE_CACHE_MAX_BYTES=134217728

# GEFS forecast-hour band the scheduler + deploy pre-warm each cycle (download-only). Default is
# the f24-f120 / 6h band (the horizon GEFS owns beyond REFS). Set [] to serve GEFS fully on
# demand (slower first briefing), or a narrower JSON list to cut warm I/O.
# UPSTREAMWX_GEFS_WARM_FHOURS=[24,30,36,42,48,54,60,66,72,78,84,90,96,102,108,114,120]

# Cap concurrent COLD briefing generations so a burst of distinct missions can't OOM/thrash the
# host — excess requests get a fast 503 "busy, retry" (the PWA shows a retry banner). Cache hits
# never count. Default 2 suits a 2-vCPU/4 GiB box; raise with more headroom, or 0 to disable. The
# busy timeout is how long a queued request waits for a free slot before the 503.
# UPSTREAMWX_BRIEFING_MAX_CONCURRENCY=2
# UPSTREAMWX_BRIEFING_BUSY_TIMEOUT_S=2.0

# ── Mission-planning input & cache hardening (SA-02) ──────────────────────────────────
# Bounds on the public /v1/briefing surface. Safe defaults live in config.py; the values
# shown ARE the defaults. On the PUBLIC (Internet-exposed) beta, set ALLOW_INPUTS_REPLAY=0.
#
# Disable the offline HazardInputs replay path. Ordinary PWA users never send `inputs`; it is a
# dev/corpus/CLI affordance that skips live ingest and pins non-expiring static cache entries —
# the durable half of the SA-02 memory-exhaustion vector. PUBLIC BETA: set to 0. Keep 1 only on
# dev/CLI hosts that actually replay saved feature vectors.
# UPSTREAMWX_API_ALLOW_INPUTS_REPLAY=0
#
# Resident byte budget for the briefing + result caches (evicts LRU until both the entry cap and
# this byte budget hold — a count cap alone doesn't bound memory). Default 256 MiB; tune to host.
# UPSTREAMWX_API_CACHE_MAX_BYTES=268435456
#
# TTL (s) for deterministic static (inputs-replay) cache entries — belt-and-suspenders behind
# ALLOW_INPUTS_REPLAY=0. Default 1 h.
# UPSTREAMWX_API_STATIC_ENTRY_TTL_S=3600
#
# App-level request-byte cap for the JSON mission endpoints (defence beyond nginx). A real
# MissionSpec is a few KB; over this is 413. Default 64 KiB.
# UPSTREAMWX_API_MAX_REQUEST_BYTES=65536
#
# Per-IP budget for cold /v1/briefing generations (cache MISSES). Cache hits are free; only cold
# ingest is charged (429 + Retry-After over budget). Default 10/min; 0 disables. Gated by
# UPSTREAMWX_API_RATE_LIMITS_ENABLED (default 1).
# UPSTREAMWX_API_BRIEFING_MISS_RATE_PER_MIN=10

# ── Scheduled-refresh workload bounds (SA-03) ─────────────────────────────────────────
# Stop one anonymous request from becoming days of recurring background work. Safe defaults
# live in config.py; the values shown ARE the defaults. All are backend-only work bounds.
#
# Refresh only RECENTLY-VIEWED missions. Every /v1/briefing (hit or miss) marks a mission viewed;
# a refresh regeneration does NOT. A mission not re-viewed within this window stops being refreshed
# (it still briefs on demand). Default 12 h ≈ two 6-hourly cycles; 0 disables the gate (refresh
# until the window ends — the old behaviour).
# UPSTREAMWX_API_ACTIVE_REFRESH_TTL_S=43200
#
# Hard per-pass caps so one refresh pass can't run unbounded work: at most this many regenerations
# (0 = unlimited) or this many wall-clock seconds (0 = unlimited), whichever comes first. Missions
# not reached refresh next cycle or on demand (NFR-6).
# UPSTREAMWX_API_REFRESH_PASS_MAX_ITEMS=64
# UPSTREAMWX_API_REFRESH_PASS_MAX_SECONDS=240
#
# How long a refresh regeneration waits for a shared generation slot before yielding the rest of the
# pass to interactive briefings. Scheduled and request generations share the concurrency cap; a short
# wait keeps refresh to spare capacity only (it never starves a real briefing). Default 0.5 s.
# UPSTREAMWX_API_REFRESH_GEN_WAIT_S=0.5

# ── Public-release access gate: anonymous fair-use sessions (SA-01) ───────────────────
# Turns "possession of the URL is the invitation" into an app-issued per-client principal so
# cost/abuse budgets attach to identity, not a bare IP. No login, no personal data. See
# api/auth.py, budget.py.
#
# SECRET-GATED ACTIVATION: the gate is ON BY DEFAULT (UPSTREAMWX_API_AUTH_ENABLED=1) but only
# ENFORCES once a signing secret is set — so a secretless host (dev/CLI/tailnet) runs open with a
# startup warning instead of crashing, while THIS public host activates the gate simply by setting
# the secret below. Set UPSTREAMWX_API_AUTH_ENABLED=0 as an operational kill-switch.
#
# 1) HMAC signing secret — THIS is what turns the gate on. Generate once:  openssl rand -hex 32
#    Keep it secret, never commit it. Every expensive /v1/* endpoint then requires a session cookie
#    the PWA mints transparently on boot; per-principal + global budgets apply. PREREQUISITE: TLS
#    must be live (the cookie is Secure — SA-09) or browsers drop it. *_PREV is verify-only, for
#    zero-downtime rotation (promote new→SECRET, old→PREV, drop PREV after one session TTL).
# UPSTREAMWX_SESSION_SECRET=
# UPSTREAMWX_SESSION_SECRET_PREV=
#
# 2) FAIL CLOSED on the public host: refuse to start if the gate is meant to be on but the secret
#    is missing, so a config slip can never silently ship /v1 open. STRONGLY RECOMMENDED here.
# UPSTREAMWX_API_AUTH_REQUIRED=1
#
# Session lifetime (s, default 7 days) and the per-IP mint rate (default 5/min).
# UPSTREAMWX_SESSION_TTL_S=604800
# UPSTREAMWX_SESSION_MINT_RATE_PER_MIN=5
# Leave the Secure cookie flag ON in production (default 1); 0 is ONLY for local http/dev.
# UPSTREAMWX_SESSION_COOKIE_SECURE=1
#
# Per-principal fair-use budgets (charged on WORK, never cache hits) and global ceilings. The
# frame/day ceiling is the model-spend cap (503 + WARNING log when hit). Defaults shown; 0 disables.
# UPSTREAMWX_BUDGET_COLD_PER_PRINCIPAL_PER_HOUR=20
# UPSTREAMWX_BUDGET_FRAME_PER_PRINCIPAL_PER_DAY=30
# UPSTREAMWX_BUDGET_PDF_PER_PRINCIPAL_PER_HOUR=20
# UPSTREAMWX_BUDGET_WARM_PER_PRINCIPAL_PER_HOUR=60
# UPSTREAMWX_BUDGET_ACTIVE_PER_PRINCIPAL=3
# UPSTREAMWX_BUDGET_GLOBAL_COLD_PER_HOUR=1200
# UPSTREAMWX_BUDGET_GLOBAL_FRAME_PER_DAY=2000
#
# Publish FastAPI's interactive docs (/docs, /redoc, /openapi.json). Default OFF in production
# (SA-12); set to 1 only on dev/staging.
# UPSTREAMWX_DOCS_ENABLED=0

# ── Host-header validation (SA-09) ────────────────────────────────────────────────────
# Restrict the Host header the app answers for. Unset (default) = no restriction (dev/CLI/tailnet).
# On the PUBLIC host set it to the app's public name(s) as a JSON list: nginx's server_name guards
# the edge, but a direct hit on the loopback uvicorn (or a drifted edge) then still 400s an unknown
# Host. The loopback names (127.0.0.1/localhost/::1) are always allowed in-app so the /v1/health
# probe and a local uvicorn keep working. JSON list form; the port is ignored when matching.
# UPSTREAMWX_API_TRUSTED_HOSTS=["app.upstreamwx.com"]

# NWS api.weather.gov requires a self-identifying User-Agent with a real contact (FR-5).
# REQUIRED for production — replace the contact with yours.
UPSTREAMWX_NWS_USER_AGENT=UpstreamWX/0.3 (+https://upstreamwx.com; chris@southeastexpeditionmed.com)

# Anthropic API key for the SITREP Haiku framing layer (FR-21). Read directly as
# ANTHROPIC_API_KEY (no UPSTREAMWX_ prefix). Without it the API returns the structured
# render only — the deterministic posture is unaffected. Leave unset to disable framing.
# ANTHROPIC_API_KEY=sk-ant-...

# The PWA is served single-origin from the repo's frontend/ by default (M0.4); no need
# to set this unless serving a packaged copy from elsewhere, or "" to disable serving.
# UPSTREAMWX_FRONTEND_DIR=

# ── PDF renderer sandbox (SA-08) ──────────────────────────────────────────────────────
# Server-side PDF export runs headless Chromium WITH its native renderer sandbox: the service
# runs as a non-root user and the systemd unit permits the user namespace the sandbox needs
# (RestrictNamespaces=user mnt pid net). If this host cannot allow unprivileged user
# namespaces (e.g. a hardened kernel, or Ubuntu 24.04+ AppArmor blocking userns), the renderer
# will fail to launch — set this to 1 to fall back to --no-sandbox (the pre-SA-08 behaviour).
# Prefer fixing the host: sysctl user.max_user_namespaces>0 and, on 24.04+,
# kernel.apparmor_restrict_unprivileged_userns=0. See deploy/README.md.
# UPSTREAMWX_PDF_NO_SANDBOX=0
