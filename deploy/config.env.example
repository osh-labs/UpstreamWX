# UpstreamWX deploy configuration (copy to deploy/config.env; git-ignored).
#
# Sourced by the deploy scripts (bootstrap.sh, deploy.sh), which run ON the server, so
# the install target is defined in ONE place. Anything here can also be overridden by an
# environment variable of the same name when invoking a script.
#
# The scripts REQUIRE an explicit DEPLOY_CONFIG (issue #146) — there is no default:
#   sudo DEPLOY_CONFIG=deploy/config.env deploy/bootstrap.sh
# One install per host is enforced: bootstrap/deploy refuse when a differently-named
# UpstreamWX service/app/data/env path already exists. To deliberately run two environments
# on one box, set DEPLOY_ALLOW_COEXIST=1 in BOTH configs and keep every name/port/path
# distinct (including DEPLOY_CTL_NAME).
# DEPLOY_ALLOW_COEXIST="0"
#
# These describe WHERE and HOW the always-on backend is installed (PRD §7, roadmap
# §M0.1.1). Application secrets (ANTHROPIC_API_KEY, etc.) do NOT live here — they go in
# the runtime EnvironmentFile (deploy/upstreamwx.env -> /etc/upstreamwx/upstreamwx.env).

# --- Source --------------------------------------------------------------------------
# Git remote the host pulls from, and the ref to deploy.
DEPLOY_REPO_URL="https://github.com/osh-labs/upstreamwx.git"
DEPLOY_BRANCH="main"

# --- On-host layout ------------------------------------------------------------------
# Install root (git checkout), service account, runtime cache dir, and env file.
DEPLOY_APP_DIR="/opt/upstreamwx"
DEPLOY_USER="upstreamwx"
DEPLOY_GROUP="upstreamwx"
DEPLOY_DATA_DIR="/var/lib/upstreamwx"
DEPLOY_ENV_DIR="/etc/upstreamwx"
DEPLOY_ENV_FILE="/etc/upstreamwx/upstreamwx.env"

# --- Service / proxy -----------------------------------------------------------------
# The uvicorn bind address (kept on loopback; nginx terminates TLS in front of it) and
# the public names nginx answers for.
DEPLOY_BIND_HOST="127.0.0.1"
DEPLOY_BIND_PORT="8000"
DEPLOY_SERVICE="upstreamwx-api"

# The app (PWA + /v1/* API, single-origin) lives on its own subdomain; the apex serves a
# static landing page (deploy/nginx/landing.conf), now from the ACTIVE release
# (DEPLOY_LANDING_ROOT defaults to <app_dir>/current/landing). Put BOTH the app name and the
# landing names in one multi-SAN cert. To run app-only with no landing (e.g. tailnet
# staging), set DEPLOY_LANDING_SERVER_NAME="".
DEPLOY_APP_SERVER_NAME="app.upstreamwx.com"
DEPLOY_LANDING_SERVER_NAME="upstreamwx.com www.upstreamwx.com"
DEPLOY_LANDING_ROOT="/opt/upstreamwx/current/landing"

# --- SA-06 atomic releases -----------------------------------------------------------
# The service runs from <app_dir>/current, a symlink deploy.sh flips atomically to a fresh
# root-owned release under <app_dir>/releases/<sha>. Defaults are derived from DEPLOY_APP_DIR;
# override only if you want a different on-disk layout. DEPLOY_KEEP_RELEASES old releases are
# retained for rollback (the active one is never pruned).
# DEPLOY_REPO_MIRROR="/opt/upstreamwx/repo"
# DEPLOY_RELEASES_DIR="/opt/upstreamwx/releases"
# DEPLOY_CURRENT_LINK="/opt/upstreamwx/current"
DEPLOY_KEEP_RELEASES="5"

# --- SA-06 uv installer verification -------------------------------------------------
# Pin the uv toolchain version AND (recommended) its installer checksum. Obtain the SHA256
# once on a trusted machine:  curl -LsSf https://astral.sh/uv/0.8.17/install.sh | sha256sum
# With it set, bootstrap refuses to run a tampered installer (SA-06). A post-install version
# assertion runs regardless.
UV_VERSION="0.8.17"
# UV_INSTALLER_SHA256=""

# --- SA-09 edge TLS (version-controlled :443 + certbot --webroot) --------------------
# Set DEPLOY_CERTBOT_EMAIL to have bootstrap issue/renew a multi-SAN cert via certbot
# --webroot (NO nginx rewrite — the :443 block is version-controlled). certbot's systemd
# timer auto-renews with an nginx-reload deploy-hook. Leave empty on tailnet staging (TLS via
# `tailscale serve`).
DEPLOY_CERTBOT_EMAIL=""
# ACME http-01 challenge webroot (served on :80 by nginx for issuance/renewal).
DEPLOY_ACME_WEBROOT="/var/www/acme"
# DEPLOY_TLS_ENABLE is managed by bootstrap (0 until a cert exists, then 1); override only to
# force HTTP-only. Cert/key paths default to certbot's live layout for the first app name.
# DEPLOY_TLS_CERT="/etc/letsencrypt/live/app.upstreamwx.com/fullchain.pem"
# DEPLOY_TLS_KEY="/etc/letsencrypt/live/app.upstreamwx.com/privkey.pem"

# --- TLS gate (SA-09) ----------------------------------------------------------------
# When "1", deploy.sh fails the deploy unless the PUBLIC endpoint serves HTTPS (valid cert)
# and plain HTTP redirects to it, and warns if the access gate / Host allowlist are not
# active on /v1/health. The SA-01 session cookie is Secure — the access gate is inert without
# live HTTPS — so the PUBLIC prod config should set this to 1 *after* certbot. Leave 0 for
# bootstrap / the first deploy / tailnet staging (no cert yet).
DEPLOY_REQUIRE_HTTPS="0"

# --- SA-07 signed-tag verification ---------------------------------------------------
# When "1", deploy.sh verifies the GPG signature of an annotated tag before building it
# (git verify-tag). Import the signer's public key into ROOT's keyring on the host. Set to 1
# on the PUBLIC prod config so a tampered/unsigned tag cannot reach production.
DEPLOY_VERIFY_TAG_SIGNATURE="0"
