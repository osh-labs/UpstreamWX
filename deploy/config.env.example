# UpstreamWX deploy configuration (copy to deploy/config.env; git-ignored).
#
# Sourced by the deploy scripts (bootstrap.sh, deploy.sh, remote-deploy.sh) so the
# install target is defined in ONE place. Anything here can also be overridden by an
# environment variable of the same name when invoking a script.
#
# These describe WHERE and HOW the always-on backend is installed (PRD §7, roadmap
# §M0.1.1). Application secrets (ANTHROPIC_API_KEY, etc.) do NOT live here — they go in
# the runtime EnvironmentFile (deploy/upstreamwx.env -> /etc/upstreamwx/upstreamwx.env).

# --- Remote host (used by remote-deploy.sh, run from a dev machine) ---------------
# SSH target that can sudo on the EC2 host. Use an ssh config alias or user@host.
DEPLOY_SSH_HOST="ubuntu@upstreamwx.example.com"
# Extra ssh options (identity file, port, etc.). Optional.
DEPLOY_SSH_OPTS=""

# --- Source --------------------------------------------------------------------------
# Git remote the host pulls from, and the ref to deploy.
DEPLOY_REPO_URL="https://github.com/osh-labs/upstreamwx.git"
DEPLOY_BRANCH="main"

# --- On-host layout ------------------------------------------------------------------
# Install root (git checkout), service account, runtime cache dir, and env file.
DEPLOY_APP_DIR="/opt/upstreamwx"
DEPLOY_USER="upstreamwx"
DEPLOY_GROUP="upstreamwx"
DEPLOY_DATA_DIR="/var/lib/upstreamwx"
DEPLOY_ENV_DIR="/etc/upstreamwx"
DEPLOY_ENV_FILE="/etc/upstreamwx/upstreamwx.env"

# --- Service / proxy -----------------------------------------------------------------
# The uvicorn bind address (kept on loopback; nginx terminates TLS in front of it) and
# the public server name nginx answers for.
DEPLOY_BIND_HOST="127.0.0.1"
DEPLOY_BIND_PORT="8000"
DEPLOY_SERVER_NAME="upstreamwx.example.com"
DEPLOY_SERVICE="upstreamwx-api"
