# UpstreamWX STAGING deploy configuration (copy to deploy/config.staging.env; git-ignored).
#
# A staging mirror of production: same scripts, distinct service name / port / paths /
# server name, so it coexists with prod on the same box (or a separate one) without
# collision. Drive it by pointing the scripts at this file:
#
#   sudo DEPLOY_CONFIG=deploy/config.staging.env deploy/bootstrap.sh      # one-time
#   sudo DEPLOY_CONFIG=deploy/config.staging.env deploy/deploy.sh main    # each update
#
# Staging deploys `main` (the next release candidate); production deploys a tag.
# See docs/deployment-workflow.md for the full release flow.

# --- Source --------------------------------------------------------------------------
DEPLOY_REPO_URL="https://github.com/osh-labs/upstreamwx.git"
DEPLOY_BRANCH="main"

# --- On-host layout (everything distinct from prod so the two never collide) ----------
DEPLOY_APP_DIR="/opt/upstreamwx-staging"
DEPLOY_USER="upstreamwx-staging"
DEPLOY_GROUP="upstreamwx-staging"
DEPLOY_DATA_DIR="/var/lib/upstreamwx-staging"
DEPLOY_ENV_DIR="/etc/upstreamwx-staging"
DEPLOY_ENV_FILE="/etc/upstreamwx-staging/upstreamwx.env"

# --- Service / proxy -----------------------------------------------------------------
# Distinct port (prod is 8000) and service name so both run side by side under systemd;
# the nginx site is named after DEPLOY_SERVICE, so it won't overwrite prod's site.
#
# Staging is app-only: one name (its tailnet MagicDNS name), no apex landing page. Set
# the app name and leave DEPLOY_LANDING_SERVER_NAME empty so bootstrap.sh skips the
# landing site. (DEPLOY_APP_SERVER_NAME falls back to the legacy DEPLOY_SERVER_NAME if
# you prefer to keep using that single variable.)
DEPLOY_BIND_HOST="127.0.0.1"
DEPLOY_BIND_PORT="8001"
DEPLOY_APP_SERVER_NAME="staging.upstreamwx.com"
DEPLOY_LANDING_SERVER_NAME=""
DEPLOY_SERVICE="upstreamwx-staging"
